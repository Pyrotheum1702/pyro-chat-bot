# Copy this file to `.env` and fill in the keys you need.
#   cp .env.example .env
# Your real `.env` is gitignored — never commit it.
# You only need a key for the providers you actually use; list_models.py
# skips any provider whose key (or SDK) is missing.

# --- Anthropic (Claude) -> ChatAnthropic ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- OpenAI (GPT / o-series) -> ChatOpenAI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Google (Gemini) -> ChatGoogleGenerativeAI ---
# https://aistudio.google.com/apikey   (GEMINI_API_KEY is also accepted)
GOOGLE_API_KEY=

# --- Fireworks AI (open models: Llama, Qwen, Mixtral, ...) -> ChatFireworks ---
# https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# --- Ollama (local models) -> ChatOllama ---
# No API key needed. Uncomment only to point at a non-default host.
# OLLAMA_HOST=http://localhost:11434

# --- RAG chatbot app config (the web app reads these; defaults shown) ---
# The chatbot uses Fireworks, so FIREWORKS_API_KEY above is required.
# CHAT_MODEL=accounts/fireworks/models/kimi-k2p6
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# TEMPERATURE=0.2
# TOP_K=4                 # chunks retrieved per question
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=150
# MAX_HISTORY=10          # prior messages fed back into the prompt
# DATA_DIR=               # where Chroma + SQLite + uploads live (Docker sets /data)
# --- security / limits ---
# MAX_UPLOAD_MB=20        # reject uploads larger than this
# MAX_MESSAGE_CHARS=8000  # reject chat messages longer than this
# ALLOW_PUBLIC_UPLOAD=false  # off = KB read-only to visitors (upload 403'd, ingest_url withheld)
# EXPOSE_CONVERSATIONS=false # off = don't expose conversation list/detail (avoids cross-visitor leak)
# TRUST_PROXY_HEADERS=false  # set true behind a trusted proxy (Caddy/NGINX) so per-IP limits use X-Forwarded-For
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=30  # per client IP, on chat + upload
# --- cost guardrail (hard daily kill-switch on LLM spend) ---
# DAILY_COST_CAP_USD=1.0    # per UTC day; chat returns 429 once hit. 0 disables.
# USD_PER_MILLION_INPUT_TOKENS=0.9   # price estimate used to meter the cap; tune to your model
# USD_PER_MILLION_OUTPUT_TOKENS=0.9
# Native embed calls the API cross-origin → list every site origin (prod + dev):
# CORS_ORIGINS=["https://pyrotheum1702.com","https://www.pyrotheum1702.com","http://localhost:17020"]
# EMBED_ORIGINS=["https://pyrotheum1702.com"]  # only needed for the iframe embed (empty = framing blocked)
# --- agent (tool-using mode) ---
# AGENT_MODEL=            # defaults to CHAT_MODEL; must support tool/function calling
# AGENT_MAX_STEPS=6
# TAVILY_API_KEY=         # optional; enables Tavily web_search (else DuckDuckGo, no key)

# --- LangSmith tracing (optional) ---
# Trace and debug your LangChain runs at https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=learning-langchain
